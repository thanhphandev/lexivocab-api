# ──────────────────────────────────────────────────────────────────
# LexiVocab Environment Configuration Template
# For development: copy to .env and fill in values
# For production:  copy to .env.production and fill in values
# ──────────────────────────────────────────────────────────────────

# ─── ASP.NET Core ────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development  # or Production

# ─── Database ────────────────────────────────────────────────────
POSTGRES_DB=lexivocab_dev           # prod: lexivocab_prod
POSTGRES_USER=postgres              # prod: use dedicated user (not postgres superuser)
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password

# ─── JWT ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your_256_bit_secret_key_min_32_chars_long
JWT_EXPIRY_MINUTES=120

# ─── Logging (SEQ) ───────────────────────────────────────────────
SEQ_ADMIN_PASSWORD=your_seq_admin_password

# ─── App URL ─────────────────────────────────────────────────────
APP_URL=https://lexivocab.store

# ─── CORS (Production only) ──────────────────────────────────────
CORS_ORIGIN_0=https://lexivocab.store
CORS_ORIGIN_1=https://www.lexivocab.store

# ─── Google OAuth ────────────────────────────────────────────────
# Lấy từ https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Ngrok (Development only — for Webhook Testing) ──────────────
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token
# Optional: Use a custom domain (paid ngrok feature)
# NGROK_DOMAIN=your-subdomain.ngrok-free.app

# ─── Sepay Payment Configuration ─────────────────────────────────
SEPAY_API_KEY=your_sepay_api_key
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_NAME=your_bank_code
SEPAY_API_BASE_URL=https://my.sepay.vn/api
# SEPAY_QR_TEMPLATE=https://qr.sepay.vn/img?acc={0}&bank={1}&amount={2}&des={3}

# ─── PayPal Configuration ────────────────────────────────────────
# sandbox: https://developer.paypal.com → Sandbox → My apps & credentials
# live:    https://developer.paypal.com → Live    → My apps & credentials
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_RETURN_URL=https://lexivocab.store/checkout/success
PAYPAL_CANCEL_URL=https://lexivocab.store/pricing
# PAYPAL_MODE=sandbox  # dev only — prod uses https://api-m.paypal.com (set in docker-compose.prod.yml)

# ─── Stripe Configuration (Optional) ─────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email Service ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SENDER_NAME=LexiVocab Team
SMTP_SENDER_EMAIL=no-reply@lexivocab.store

# ─── AI Providers ────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-pro-1.5
OPENROUTER_MAX_TOKENS=4096
FIREWORKS_API_KEY=your_fireworks_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── Cloudflare AI Worker ─────────────────────────────────────────
CLOUDFLARE_AI_API_KEY=your_cloudflare_worker_api_key
CLOUDFLARE_AI_WORKER_URL=https://your-worker.workers.dev
