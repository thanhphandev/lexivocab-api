# ──────────────────────────────────────────────────────────────────
# LexiVocab Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ──────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────
POSTGRES_DB=lexivocab_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=your_256_bit_secret_key_min_32_chars_long
JWT_EXPIRY_MINUTES=120

# ─── Logging (SEQ) ───────────────────────────────────────────────
SEQ_ADMIN_PASSWORD=your_seq_admin_password

# ─── Ngrok (for Webhook Testing) ─────────────────────────────────
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token
# Optional: Use a custom domain (paid ngrok feature)
# NGROK_DOMAIN=your-subdomain.ngrok-free.app

# ─── Sepay Payment Configuration ─────────────────────────────────
# REQUIRED: Bank account info for VietQR generation
SEPAY_API_KEY=your_sepay_api_key
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_NAME=your_bank_code  # e.g., MB (Military Bank), VCB (Vietcombank), TCB (Techcombank)
# Sepay API URL - Use production for live transactions
SEPAY_API_BASE_URL=https://my.sepay.vn/api  # Production
# SEPAY_API_BASE_URL=https://sandbox.sepay.vn/api  # Sandbox for testing
# Optional: Custom QR template (default works for most cases)
# SEPAY_QR_TEMPLATE=https://qr.sepay.vn/img?acc={0}&bank={1}&amount={2}&des={3}

# ─── PayPal Configuration (Optional) ─────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # or 'live' for production

# ─── Stripe Configuration (Optional) ─────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email Service (Optional) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
