# ──────────────────────────────────────────────────────────────────
# LexiVocab Environment Configuration Template
# For development: copy to .env and fill in values
# For production:  copy to .env.production and fill in values
# ──────────────────────────────────────────────────────────────────

# ─── ASP.NET Core ─────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ─── Database (PostgreSQL) ────────────────────────────────
POSTGRES_DB=lexivocab_dev
POSTGRES_USER=postgres_app
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=your_secure_redis_password_here

# ─── JWT ──────────────────────────────────────────────────
# Generate: openssl rand -hex 32 or random string
JWT_SECRET=your_256_bit_secret_key_min_32_chars_long_here
JWT_EXPIRY_MINUTES=120
JWT_REFRESH_EXPIRY_DAYS=30
JWT_REFRESH_GRACE_PERIOD_SECONDS=60
JWT_CLOCK_SKEW_SECONDS=0

# ─── SEQ Logging ──────────────────────────────────────────
SEQ_ADMIN_PASSWORD=your_seq_admin_password_here

# ─── App URL ──────────────────────────────────────────────
APP_URL=https://lexivocab.store

# ─── Google OAuth ─────────────────────────────────────────
# Lấy từ https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Sepay Payment ────────────────────────────────────────
SEPAY_API_KEY=your_sepay_api_key_here
SEPAY_BANK_ACCOUNT=your_bank_account_number_here
SEPAY_BANK_NAME=your_bank_code_here
SEPAY_API_BASE_URL=https://my.sepay.vn/api
SEPAY_QR_TEMPLATE=https://qr.sepay.vn/img?acc={0}&bank={1}&amount={2}&des={3}

# Lấy từ https://developer.paypal.com → My Apps & Credentials → LIVE tab
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=REPLACE_WITH_PAYPAL_LIVE_WEBHOOK_ID
PAYPAL_RETURN_URL={APP_URL}/checkout/success
PAYPAL_CANCEL_URL={APP_URL}/pricing

# ─── Email (Resend) ───────────────────────────────────────
# Resend is the preferred email provider for simple integration.
RESEND_API_KEY=your_resend_api_key_here
RESEND_SENDER_NAME=LexiVocab Team
RESEND_SENDER_EMAIL=no-reply@lexivocab.store

# ─── Email (SMTP) ─────────────────────────────────────────
# Fallback if Resend is not configured.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_SENDER_NAME=LexiVocab Team
SMTP_SENDER_EMAIL=no-reply@lexivocab.store

# ─── AI Providers ─────────────────────────────────────────
AI_DEFAULT_PROVIDER=custom
AI_CUSTOM_API_KEY=your_ai_custom_api_key_here
AI_CUSTOM_BASE_URL=http://host.docker.internal:20128/v1
AI_CUSTOM_DEFAULT_MODEL=cx/gpt-5.4
AI_CUSTOM_MAX_TOKENS=4096

# --- Encryption ------------------------------------------
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=your_base64_encoded_encryption_key_here
