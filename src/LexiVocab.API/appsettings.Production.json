{
    "ConnectionStrings": {
        "DefaultConnection": "Host=prod-db-host;Port=5432;Database=lexivocab_prod;Username=postgres;Password=SECURE_PASSWORD;Maximum Pool Size=25;Pooling=true;Connection Idle Lifetime=300",
        "Redis": "redis-host:6379,password=SECURE_REDIS_PASSWORD,ssl=True,abortConnect=false,connectRetry=3"
    },
    "RUN_MIGRATIONS": true,
    "Cors": {
        "AllowedOrigins": [
            "https://lexivocab.store",
            "https://www.lexivocab.store"
        ]
    },
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Error",
            "Hangfire": "Warning"
        }
    },
    "PayPal": {
        "BaseUrl": "https://api-m.paypal.com",
        "ReturnUrl": "https://lexivocab.store/checkout/success",
        "CancelUrl": "https://lexivocab.store/pricing"
    },
    "Smtp": {
        "UseSsl": true
    },
    "AllowedHosts": "lexivocab.store;*.lexivocab.store"
}